{
   "id": "hv_hp",
   "title": "Hv Hauptsignal",
   "atlas": "hv",
   "scale": 0.125,
   "previewsize": 20,
   "initial": [
      "hp=0",
      "vr=0",
      "HPsig",
      "verw='asig'",
      "mastschild='wrw'"
   ],
   "rules": [
      [
         "hp>0 && currentSpeed>6",
         "hp=1"
      ],
      [
         "hp>0 && currentSpeed<=6 && currentSpeed>0",
         "hp=2"
      ]
   ],
   "menu": [
      {
         "section": [
            {
               "buttonGroup": [
                  { "text": "Hp 0", "command": "hp=0" },
                  { "text": "Hp 1", "command": "hp=1" },
                  { "text": "Hp 2", "command": "hp=2" }
               ]
            },
            {
               "dropdown": {
                  "text": "Zs3",
                  "command": "currentSpeed"
               }
            }
         ]
      },
      {
         "section": [
            {
               "buttonGroup": [
                  { "text": "Vr 0", "command": "vr=0" },
                  { "text": "Vr 1", "command": "vr=1" },
                  { "text": "Vr 2", "command": "vr=2" }
               ]
            },
            {
               "button": {
                  "text": "verk",
                  "command": "verk=1"
               }
            },
            {
               "dropdown": {
                  "text": "Zs3v",
                  "command": "advanceSpeed"
               }
            }
         ]
      },
      {
         "section": [
            {
               "buttonGroup": [
                  { "text": "Zs 1", "command": "ersatz='zs1'" },
                  { "text": "Zs 7", "command": "ersatz='zs7'" },
                  { "text": "Zs 8", "command": "ersatz='zs8'" },
                  { "text": "Sh 1", "command": "ersatz='sh1'" },
                  { "text": "Kennlicht", "command": "ersatz='kennlicht'" }
               ]
            },
            {
               "button": {
                  "text": "Zs 6",
                  "command": "zs6=1"
               }
            }
         ]
      }
   ],
   "config_options": [
      {
         "name": "mastschild='wrw'",
         "title": "W-R-W",
         "convertTo": "mastschild='wgwgw'"
      },
      {
         "name": "mastschild='wgwgw'",
         "title": "W-G-W-G-W",
         "convertTo": "mastschild='wrw'"
      }
   ],
   "dependency": {
      "publish": {
         "route": [
            ["hp<=0", "stop"],
            ["hp>=1", "go"]
         ],
         "currentSpeed": [
            ["hp=2&&currentSpeed<=0", 4]
         ]
      },
      "when": ["partner.HPsig && ersatz!='kennlicht'"],
      "unless": ["self.HPsig&&self.hp=0", "self.vr=-1"],
      "subscribe": {
         "vr": { "route": { "stop": 0, "go": 1 } }
      },
      "overrides": [
         ["partner.currentSpeed=4", { "advanceSpeed": 0, "vr": 2, "when": "self.vr>0" }]
      ],
      "stopUnless": "vr_op='wdh'"
   },
   "elements": [
      "mast,hp_schirm",
      {
         "image": "wrw",
         "on": "mastschild='wrw'"
      },
      {
         "image": "wgwgw",
         "on": "mastschild='wgwgw'"
      },
      {
         "image": "hp_asig_lichtp",
         "on": "verw='asig'||verw='zsig'"
      },
      {
         "image": "hp_bk_lichtp_unten",
         "on": "verw='bksig'||verw='sbk'||verw='esig'"
      },
      {
         "image": "hp_bk_lichtp_oben",
         "on": "verw='bksig'||verw='esig'"
      },
      {
         "on": "hp=0",
         "children": [
            {
               "image": "hp_asig_rot_re",
