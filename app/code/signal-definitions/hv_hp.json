            }
         ]
      },
      {
         "on": "hp=1",
         "off": "currentSpeed<=6 && currentSpeed>0",
         "children": [
            {
               "image": "hp_asig_gr",
               "on": "verw='asig'||verw='zsig'"
            },
            {
               "image": "hp_bk_gr_unten_re",
