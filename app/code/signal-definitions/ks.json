      {
         "section": [
            {
               "buttonGroup": [
                  { "text": "Hp 0", "command": "hp=0" },
                  { "text": "Ks 1", "command": "hp=1" },
                  { "text": "Ks 2", "command": "hp=2" }
               ]
            },
            {
               "dropdown": {
                  "text": "Zs3",
                  "command": "currentSpeed"
               }
            }
         ]
      },
      {
         "section": [
            {
               "dropdown": {
                  "text": "Zs3v",
                  "command": "advanceSpeed"
               }
            }
         ]
      },
      {
         "section": [
            {
               "buttonGroup": [
                  { "text": "Zs 1", "command": "ersatz='zs1'" },
                  { "text": "Zs 7", "command": "ersatz='zs7'" },
                  { "text": "Zs 8", "command": "ersatz='zs8'" },
                  { "text": "Sh 1", "command": "ersatz='sh1'" },
                  { "text": "Kennlicht", "command": "ersatz='kennlicht'" }
               ]
            }
         ]
      },
      {
         "section": [
            {
               "button": {
                  "text": "Zs 6",
                  "command": "zs6=1"
               }
            },         
            {
               "button": {
                  "text": "Zs 13",
                  "command": "zs13=1"
               }
            },
            {
               "button": {
                  "text": "Zp 9",
                  "command": "zp9=1"
               }
            }
         ]
      }
   ],
   "config_options": [
      {
         "name": "mast",
         "title": "Mast geknickt",
         "convertTo": "mast2"
      },
      {
         "name": "mast2",
         "title": "Mast gerade",
         "convertTo": "mast"
      }
   ],
   "dependency": {
      "when": ["partner.HPsig"],
      "unless": ["self.HPsig&&self.hp=0", "self.hp=-1"],
      "publish": {
         "route": [
            ["hp<=0", "stop"],
            ["hp>=1", "go"]
         ]
      },
      "subscribe": {
         "hp": {
            "route": {
               "stop": 2,
               "go": 1
            }
         }
      },
      "stopUnless": "vr_op='wdh'"
   },
   "elements": [
      {
         "image": "zs3_licht",
         "on": "zusatz_oben",
         "children": [
            {
               "text": "currentSpeed",
               "format": [85, "DOT"],
               "pos": [90, 40],
               "on": "currentSpeed>0",
               "off": "hp<=0"
            }
         ]
      },
      {
         "on": "currentSpeed>0",
         "off": "zusatz_oben",
         "children": [
            "zs3",
            {
               "text": "currentSpeed",
               "format": [80, "Arial", 1],
               "pos": [85, 70]
            }
         ]
      },
      {
         "image": "mast",
         "on": "mast",
         "off": "mast2"
      },
      {
         "image": "mast2",
         "on": "mast2",
         "off": "mast"
      },
      {
         "image": "wrw",
         "on": "mast",
         "off": "mast2"
      },
      {
         "image": "wrw2",
         "on": "mast2",
         "off": "mast"
      },
      "schirm_hp",
      {
         "on": "VRsig",
         "children": [
            "ks1_2_optik_hpvr",
            {
               "image": "ks2",
               "on": "hp=2"
            }
         ]
      },
      {
         "image": "ks1_optik_hp",
         "off": "VRsig"
      },
      {
         "on": "hp=1",
         "children": [
            {
               "image": "ks1_hpvr",
               "on": "VRsig&&advanceSpeed>0",
               "off": "currentSpeed>0&&currentSpeed<=advanceSpeed",
               "blinks": true
            },
            {
               "image": "ks1_hpvr",
               "on": "VRsig",
               "off": "advanceSpeed>0&&currentSpeed>advanceSpeed"
            },
            {
               "image": "ks1_hp",
               "on": "advanceSpeed>0",
               "off": "VRsig",
               "blinks": true
            },
            {
               "image": "ks1_hp",
               "off": "VRsig||advanceSpeed"
            }
         ]
      },
      {
         "on": "VRsig",
         "children": [
            {
               "image": "möhre",
               "on": "mast"
            },
            {
               "image": "möhre2",
               "on": "mast2"
            }
         ]
      },
      {
         "image": "hp0",
         "on": "hp=0"
      },
      {
         "on": "verw='asig'||verw='bksig'||verw='sbk'",
         "children": [
            "zs1_optik",
            {
               "image": "zs1",
               "on": "ersatz='zs1'",
               "off": "hp>0",
               "blinks": true
            }
         ]
      },
      {
         "on": "verw='esig'||verw='zsig'",
         "children": [
            "zs7_optik",
            {
               "image": "zs7",
               "on": "ersatz='zs7'",
               "off": "hp>0"
            }
         ]
      },
      {
         "on": "verw='asig'||verw='zsig'",
         "children": [
            "sh1_optik",
            "zs1_optik",
            {
               "image": "zs1,sh1",
               "on": "ersatz='sh1'",
               "off": "hp>0"
            }
         ]
      },
      {
         "on": "vr_op='verk'&&VRsig",
         "children": [
            "kennlicht_optik",
            {
               "image": "kennlicht",
               "off": "hp=0||hp=1&&(advanceSpeed<=0||currentSpeed>0&&currentSpeed<=advanceSpeed)"
            }
         ]
      },
      {
         "on": "verw='asig'||verw='zsig'",
         "children": [
            "kennlicht_optik",
            {
               "image": "kennlicht",
               "on": "ersatz='kennlicht'",
               "off": "hp>=0"
            }
         ]
      },
      {
         "on": "advanceSpeed>0",
         "off": "zusatz_unten||currentSpeed>0&&currentSpeed<=advanceSpeed",
         "children": [
            "zs3v",
            {
               "text": "advanceSpeed",
               "format": [80, "Arial", 1],
               "color": "#ffde36",
               "pos": [85, 490]
            }
         ]
      },
      {
         "image": "zs3v_licht",
         "on": "zusatz_unten",
         "children": [
            {
               "text": "advanceSpeed",
               "format": [85, "DOT"],
               "color": "#ffde36",
               "on": "advanceSpeed>0",
               "off": "hp<=0||currentSpeed>0&&currentSpeed<=advanceSpeed",
               "pos": [90, 520]
            }
         ]
      },
      {
         "on": "zs6=1&&zusatz_oben",
         "off": "hp<=0||currentSpeed>0&&advanceSpeed>0",
         "children": [
            {
               "image": "zs6_licht",
               "off": "currentSpeed>0"
            },
            {
               "image": "zs6_licht",
               "on": "currentSpeed>0",
               "pos": [40, 500]
            }
         ]
      },
      {
         "image": "zs13",
         "on": "zs13=1&&zusatz_unten",
         "off": "hp=0||advanceSpeed>0||zp9=1||zs6=1"
      },
      {
         "on": "zp9=1&&zusatz_unten",
         "off": "hp=0||zs13=1||zs6=1||advanceSpeed>0",
         "children": [
            {
               "image": "zp9",
               "on": "zp9=1"
            }
         ]
      },
      {
         "image": "schild",
         "on": "bez",
         "children": [
            {
               "text": "bez",
               "format": [55, "condenced", 1],
               "color": "#333",
               "pos": [85, 626]
            }
         ]
      }
   ]
}
