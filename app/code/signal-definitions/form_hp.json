{
   "id": "form_hp",
   "title": "Form Hauptsignal",
   "atlas": "formsignal",
   "scale": 0.2,
   "previewsize": 20,
   "initial": [
      "hp=0",
      "HPsig"
   ],
   "menu": [
      {
         "section": [
            {
               "buttonGroup": [
                  { "text": "Hp 0", "command": "hp=0" },
                  { "text": "Hp 1", "command": "hp=1" },
                  { "text": "Hp 2", "command": "hp=2" }
               ]
            },
            {
               "dropdown": {
                  "text": "Zs3",
                  "command": "currentSpeed"
               }
            }
         ]
      },
      {
         "section": [
            {
               "buttonGroup": [
                  { "text": "Vr 0", "command": "vr=0" },
                  { "text": "Vr 1", "command": "vr=1" },
                  { "text": "Vr 2", "command": "vr=2" }
               ]
            },
            {
               "button": {
                  "text": "verk",
                  "command": "verk=1"
               }
            },
            {
               "dropdown": {
                  "text": "Zs3v",
                  "command": "advanceSpeed"
               }
            }
         ]
      },
      {
         "section": [
            {
               "buttonGroup": [
                  { "text": "Zs 1", "command": "ersatz='zs1'" },
                  { "text": "Zs 7", "command": "ersatz='zs7'" },
                  { "text": "Zs 8", "command": "ersatz='zs8'" },
                  { "text": "Sh 1", "command": "ersatz='sh1'" },
                  { "text": "Kennlicht", "command": "ersatz='kennlicht'" }
               ]
            }
         ]
      },
      {
         "section": [
            {
               "button": {
                  "text": "Zs 6",
                  "command": "zs6=1"
               }
            }
         ]
      }
   ],
   "config_options": [
      {
         "name": "3_begriffig=1",
         "title": "Dreibegriffig"
      }
   ],
   "dependency": {
      "publish": {
         "route": [
            ["hp<=0", "stop"],
            ["hp>=1", "go"]
         ],
         "currentSpeed": [
            ["hp=2&&currentSpeed<=0", 4],
            ["else", "currentSpeed"]
         ]
      },
      "when": ["partner.HPsig", "self.VRsig"],
      "unless": ["self.HPsig&&self.hp=0", "self.vr=-1"],
      "subscribe": {
         "vr": { "route": { "stop": 0, "go": 1 } }
      },
      "overrides": [
         ["partner.currentSpeed=4", { "advanceSpeed": 0, "vr": 2, "when": "self.vr>0" }]
      ],
      "stopUnless": "vr_op='wdh'"
   },
   "elements": [
      {
         "image": "hp2_assembly,lichtscheibe_hintergrund_unten,lichtscheibe_licht_unten",
         "on": "3_begriffig=1"
      },
      "mast,flügel_oben",
      "lichtscheibe_hintergrund",
      "lichtscheibe_licht",
      {
         "label": "lichtscheibe",
         "image": "lichtscheibe_rahmen",
         "children": [
            {
               "image": "lichtscheibe_farbfilter",
               "blendMode": "multiply"
            }
         ]
      },
      {
         "image": "flügel_unten",
         "on": "3_begriffig=1"
      },
      {
         "on": "3_begriffig=1",
         "label": "lichtscheibe_unten",
         "image": "lichtscheibe_rahmen_unten",
         "children": [
            {
               "image": "lichtscheibe_farbfilter_unten",
               "blendMode": "multiply"
            }
         ]
      },
      {
         "on": "hp=0",
         "rotation": [
            {
               "element": "flügel_oben",
               "angle": 0,
               "pivot": [
                  36.5,
                  25.5
               ]
            },
            {
               "element": [
                  "lichtscheibe",
                  "lichtscheibe_hintergrund"
               ],
               "angle": 0,
               "pivot": [
                  3,
                  15
               ]
            },
            {
               "element": "flügel_unten",
               "angle": 0,
               "pivot": [
                  25.5,
                  154
               ]
            },
            {
               "element": [
                  "lichtscheibe_unten",
                  "lichtscheibe_hintergrund_unten"
               ],
               "angle": 0,
               "pivot": [
                  3,
                  15
               ]
            }
         ]
      },
      {
         "on": "hp=2",
         "rotation": [
            {
               "element": "flügel_unten",
               "angle": 42,
               "pivot": [
                  25.5,
                  154
               ]
            },
            {
               "element": [
                  "lichtscheibe_unten",
                  "lichtscheibe_hintergrund_unten"
               ],
               "angle": -62,
               "pivot": [
                  3,
                  15
               ]
            }
         ]
      },
      {
         "on": "hp=1||hp=2",
         "rotation": [
            {
               "element": "flügel_oben",
               "angle": -42,
               "pivot": [
                  36.5,
                  25.5
               ]
            },
            {
               "element": [
                  "lichtscheibe",
                  "lichtscheibe_hintergrund"
               ],
               "angle": -62,
               "pivot": [
                  3,
                  15
               ]
            }
         ]
      }
   ]
}
