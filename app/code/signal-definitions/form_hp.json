{
   "id": "form_hp",
   "title": "Form Hauptsignal",
   "atlas": "formsignal",
   "scale": 0.24,
   "previewsize": 20,
   "initial": ["hp=0", "HPsig"],
   "menu": [
      {
         "section": [
            {
               "buttonGroup": [
                  { "text": "Hp 0", "command": "hp=0" },
                  { "text": "Hp 1", "command": "hp=1" },
                  { "text": "Hp 2", "command": "hp=2" }
               ]
            },
            {
               "dropdown": {
                  "text": "Zs3",
                  "command": "currentSpeed"
               }
            }
         ]
      },
      {
         "section": [
            {
               "buttonGroup": [
                  { "text": "Zs 1", "command": "ersatz='zs1'" }
               ]
            }
         ]
      }
   ],
   "config_options": [
      {
         "name": "3_begriffig=1",
         "title": "Dreibegriffig"
      },
      {
         "name": "ersatz_zs1=1",
         "title": "Ersatzsignal"
      }
   ],
   "dependency": {
      "publish": {
         "route": [
            ["hp<=0", "stop"],
            ["hp>=1", "go"]
         ],
         "currentSpeed": [["hp=2&&currentSpeed<=0", 4]]
      },
      "when": ["partner.HPsig"],
      "unless": ["self.HPsig&&self.hp=0", "self.vr=-1"],
      "subscribe": {
         "vr": { "route": { "stop": 0, "go": 1 } }
      },
      "overrides": [["partner.currentSpeed=4", { "advanceSpeed": 0, "vr": 2, "when": "self.vr>0" }]],
      "stopUnless": "vr_op='wdh'"
   },
   "elements": [
      {
         "image": "hp2_assembly,lichtscheibe_hintergrund_unten,lichtscheibe_licht_unten",
         "on": "3_begriffig=1"
      },
      "mast,flügel_oben",
      "lichtscheibe_hintergrund",
      "lichtscheibe_licht",
      {
         "label": "lichtscheibe",
         "image": "lichtscheibe_rahmen",
         "children": [
            {
               "image": "lichtscheibe_farbfilter",
               "blendMode": "multiply"
            }
         ]
      },
      {
         "image": "flügel_unten",
         "on": "3_begriffig=1"
      },
      {
         "on": "3_begriffig=1",
         "label": "lichtscheibe_unten",
         "image": "lichtscheibe_rahmen_unten",
         "children": [
            {
               "image": "lichtscheibe_farbfilter_unten",
               "blendMode": "multiply"
            }
         ]
      },
      {
         "on": "hp=0",
         "rotation": [
            {
               "element": "flügel_oben",
               "angle": 0,
               "pivot": [36.5, 25.5]
            },
            {
               "element": ["lichtscheibe", "lichtscheibe_hintergrund"],
               "angle": 0,
               "pivot": [3, 15]
            },
            {
               "element": "flügel_unten",
               "angle": 0,
               "pivot": [25.5, 154]
            },
            {
               "element": ["lichtscheibe_unten", "lichtscheibe_hintergrund_unten"],
               "angle": 0,
               "pivot": [3, 15]
            }
         ]
      },
      {
         "on": "hp=2",
         "rotation": [
            {
               "element": "flügel_unten",
               "angle": 42,
               "pivot": [25.5, 154]
            },
            {
               "element": ["lichtscheibe_unten", "lichtscheibe_hintergrund_unten"],
               "angle": -62,
               "pivot": [3, 15]
            }
         ]
      },
      {
         "on": "hp=1",
         "rotation": [
            {
               "element": "flügel_unten",
               "angle": 0,
               "pivot": [25.5, 154]
            },
            {
               "element": ["lichtscheibe_unten", "lichtscheibe_hintergrund_unten"],
               "angle": 0,
               "pivot": [3, 15]
            }
         ]
      },
      {
         "on": "hp=1||hp=2",
         "rotation": [
            {
               "element": "flügel_oben",
               "angle": -42,
               "pivot": [36.5, 25.5]
            },
            {
               "element": ["lichtscheibe", "lichtscheibe_hintergrund"],
               "angle": -62,
               "pivot": [3, 15]
            }
         ]
      },
      {
         "on": "ersatz_zs1=1",
         "image": "zs1_aus",
         "children": [
            {
               "image": "zs1",
               "on": "ersatz='zs1'"
            }
         ]
      },
      {
         "on": "currentSpeed>0",
         "children": [
            "zs3_blech",
            {
               "text": "currentSpeed",
               "format": [50, "Arial", 1],
               "pos": [46, 422]
            }
         ]
      }
   ]
}
