{
   "id": "ks_vr",
   "title": "Ks Vorsignal",
   "atlas": "ks",
   "scale": 0.13,
   "previewsize": 20,
   "initial": [
      "VRsig",
      "hp=2",
      "mast"
   ],
   "menu": [
      {
         "section": [
            {
               "buttonGroup": [
                  { "text": "Ks 1", "command": "hp=1" },
                  { "text": "Ks 2", "command": "hp=2" }
               ]
            }
         ]
      },
      {
         "section": [
            {
               "dropdown": {
                  "text": "Zs3v",
                  "command": "advanceSpeed"
               }
            }
         ]
      },
      {
         "section": [
            {
               "button": {
                  "text": "Kennlicht",
                  "command": "ersatz='kennlicht'"
               }
            }
         ]
      }
   ],
   "config_options": [
      {
         "name": "mast",
         "title": "Mast geknickt",
         "convertTo": "mast2"
      },
      {
         "name": "mast2",
         "title": "Mast gerade",
         "convertTo": "mast"
      }
   ],
   "dependency": {
      "when": ["partner.HPsig"],
      "unless": ["self.HPsig&&self.hp=0", "self.hp=-1"],
      "subscribe": {
         "hp": { "route": { "stop": 2, "go": 1 } }
      },
      "stopUnless": "vr_op='wdh'"
   },
   "elements": [
      {
         "image": "mast",
         "on": "mast",
         "off": "mast2"
      },
      {
         "image": "mast2",
         "on": "mast2",
         "off": "mast"
      },
      "schirm_vr",
      {
         "image": "ks2_vr",
         "on": "hp=2"
      },
      {
         "on": "hp=1",
         "children": [
            {
               "image": "ks1_vr",
               "on": "advanceSpeed>0",
               "blinks": true
            },
            {
               "image": "ks1_vr",
               "off": "advanceSpeed>0"
            }
         ]
      },
      {
         "on": "vr_op='wdh'",
         "image": "vr_wdh_optik",
         "children": [
            {
               "image": "vr_wdh_licht",
               "off": "hp=1&&advanceSpeed<=0"
            }
         ]
      },
      {
         "off": "vr_op='wdh'",
         "children": [
            {
               "image": "ne2",
               "on": "mast"
            },
            {
               "image": "ne2",
               "on": "mast2",
               "pos": [
                  30,
                  1000
               ]
            }
         ]
      },
      {
         "on": "vr_op='verk'",
         "image": "vr_verk_optik",
         "children": [
            {
               "image": "vr_verk_licht",
               "off": "hp=1&&advanceSpeed<=0"
            }
         ]
      },
      {
         "on": "advanceSpeed>0",
         "off": "zusatz_unten",
         "children": [
            "zs3v",
            {
               "text": "advanceSpeed",
               "format": [
                  80,
                  "Arial",
                  1
               ],
               "color": "#ffde36",
               "pos": [
                  85,
                  490
               ]
            }
         ]
      },
      {
         "image": "zs3v_licht",
         "on": "zusatz_unten",
         "children": [
            {
               "text": "advanceSpeed",
               "format": [
                  85,
                  "DOT"
               ],
               "color": "#ffde36",
               "on": "advanceSpeed>0",
               "off": "hp<=0",
               "pos": [
                  90,
                  520
               ]
            }
         ]
      }
   ]
}
